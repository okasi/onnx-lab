{
  "version": 1,
  "description": "Gemma 4 multimodal smoke tasks — image description and audio transcription.",
  "tasks": [
    {
      "id": "image-artemis",
      "modality": "image",
      "media_url": "https://huggingface.co/datasets/Xenova/transformers.js-docs/resolve/main/artemis.jpeg",
      "prompt": "Describe this image in one sentence.",
      "max_new_tokens": 48,
      "expect_substrings": ["flag", "rocket", "launch", "sky", "american"]
    },
    {
      "id": "audio-jfk",
      "modality": "audio",
      "media_url": "https://huggingface.co/datasets/Xenova/transformers.js-docs/resolve/main/jfk.wav",
      "prompt": "Transcribe the audio verbatim.",
      "max_new_tokens": 96,
      "expect_substrings": ["americans", "country", "ask not"]
    }
  ]
}
