{
  "name": "onnx-lab",
  "version": "1.0.0",
  "description": "ONNX model lab — embeddings and LLMs with Transformers.js (WASM, CPU, WebGPU) and benchmarks",
  "type": "module",
  "scripts": {
    "generate:corpus": "node scripts/generate-corpus.mjs",
    "benchmark": "node --expose-gc scripts/benchmark.mjs",
    "benchmark:quick": "node --expose-gc scripts/benchmark.mjs --quick",
    "benchmark:smoke": "node --expose-gc scripts/benchmark.mjs --max-texts 3 --dtype bnb4,int8,q4,q4f16,quantized,uint8",
    "leaderboard": "node scripts/generate-leaderboard.mjs",
    "probe:embeddinggemma": "node --expose-gc scripts/probe-embeddinggemma-backends.mjs",
    "probe:webgpu": "node scripts/probe-webgpu-hard.mjs",
    "probe:webgpu:browser": "node scripts/probe-webgpu-browser-strategy.mjs browser:q4-control",
    "probe:gemma-quants": "node scripts/probe-gemma-quant-matrix.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/okasi/onnx-lab.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/okasi/onnx-lab/issues"
  },
  "homepage": "https://github.com/okasi/onnx-lab#readme",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "playwright-core": "^1.61.0",
    "webgpu": "^0.4.0"
  }
}
