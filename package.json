{
  "name": "embedding-tests",
  "version": "1.0.0",
  "description": "Swedish/Turkish embedding benchmarks with Transformers.js WASM on Node.js",
  "type": "module",
  "scripts": {
    "generate:corpus": "node scripts/generate-corpus.mjs",
    "benchmark": "node --expose-gc scripts/benchmark.mjs",
    "benchmark:quick": "node --expose-gc scripts/benchmark.mjs --quick",
    "benchmark:smoke": "node --expose-gc scripts/benchmark.mjs --max-texts 3 --dtype bnb4,fp16,int8,q4,q4f16,quantized,uint8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/okasi/embedding-tests.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/okasi/embedding-tests/issues"
  },
  "homepage": "https://github.com/okasi/embedding-tests#readme",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
